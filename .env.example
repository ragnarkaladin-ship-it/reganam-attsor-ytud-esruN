
# Database Configuration
# Options: postgres, mongodb, firebase, memory
DB_TYPE=postgres
# Set to true to drop and recreate tables on startup
DB_RESET=false

# PostgreSQL Configuration
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=nurseshift

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/nurseshift

# Firebase Configuration
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_DATABASE_URL=
